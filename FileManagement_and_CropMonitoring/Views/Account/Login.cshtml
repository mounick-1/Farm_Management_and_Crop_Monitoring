@model FarmManagement_and_CropMonitoring.Models.User
@{
    Layout = null; // Disables the default _Layout navbar/footer for this page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - FarmAdmin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            body {
                /* Background Overlay + Farm Image */
                background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1350&q=80');
                background-size: cover;
                background-position: center;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .login-card {
                background: rgba(255, 255, 255, 0.95);
                border-radius: 15px;
                padding: 40px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.3);
                width: 100%;
                max-width: 400px;
            }

            .btn-farm {
                background-color: #28a745;
                border: none;
                color: white;
                font-weight: bold;
                text-transform: uppercase;
                transition: 0.3s;
            }

                .btn-farm:hover {
                    background-color: #218838;
                    color: white;
                    transform: translateY(-2px);
                }

            .form-floating label {
                color: #6c757d;
            }
    </style>
</head>
<body>

    <div class="login-card text-center">
        <img src="/images/logo.png" alt="Farm Logo" style="height: 80px; margin-bottom: 20px;">
        
        <h4 class="fw-bold text-uppercase mb-4">FarmAdmin Portal</h4>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" style="font-size: 0.9rem;">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            <div class="form-floating mb-3">
                <input type="text" class="form-control" id="userInput" name="username" placeholder="Username" required>
                <label for="userInput">Username</label>
            </div>
            
            <div class="form-floating mb-4">
                <input type="password" class="form-control" id="passInput" name="password" placeholder="Password" required>
                <label for="passInput">Password</label>
            </div>

            <button type="submit" class="btn btn-farm w-100 py-2 rounded-pill shadow-sm">
                Login to Dashboard
            </button>
        </form>

        <p class="mt-4 text-muted" style="font-size: 0.8rem;">
            <i class="bi bi-lock-fill"></i> Authorized Personnel Only
        </p>
    </div>

</body>
</html>