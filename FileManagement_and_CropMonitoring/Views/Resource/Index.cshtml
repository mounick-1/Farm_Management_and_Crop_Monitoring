@model IEnumerable<FarmManagement_and_CropMonitoring.Models.Resource>

@{
    ViewData["Title"] = "Resource Inventory";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Farm Resources (Inventory)</h1>
        <a asp-action="Create" class="btn btn-info text-white">Add New Resource</a>
    </div>

    <table class="table table-striped border">
        <thead class="table-dark">
            <tr>
                <th>Resource Name</th>
                <th>Category</th>
                <th>Quantity in Stock</th>
                <th>Unit</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ResourceName</td>
                        <td>@item.Category</td>
                        <td>@item.QuantityInStock</td>
                        <td>@item.Unit</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No resources in stock.</td>
                </tr>
            }
        </tbody>
    </table>
</div>