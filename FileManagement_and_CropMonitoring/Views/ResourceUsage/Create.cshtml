@model FarmManagement_and_CropMonitoring.Models.ResourceUsage

<div class="container mt-4">
    <h1>Record Resource Usage</h1>
    <form asp-action="Create">
        <div class="form-group mb-3">
            <label>Select Crop</label>
            <select asp-for="CropId" class="form-control" asp-items="ViewBag.CropId"></select>
        </div>

        <div class="form-group mb-3">
            <label>Select Resource</label>
            <select asp-for="ResourceId" class="form-control" asp-items="ViewBag.ResourceId"></select>
        </div>

        <div class="form-group mb-3">
            <label asp-for="QuantityUsed"></label>
            <input asp-for="QuantityUsed" class="form-control" type="number" step="0.01" />
    
            <span asp-validation-for="QuantityUsed" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Date Used</label>
            <input asp-for="DateUsed" class="form-control" type="date" />
        </div>

        <button type="submit" class="btn btn-primary">Record Usage</button>
    </form>
</div>