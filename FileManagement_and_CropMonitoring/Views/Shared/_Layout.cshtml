<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FarmAdmin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FileManagement_and_CropMonitoring.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.png" alt="FarmAdmin Logo" style="height: 60px; width: auto; margin-right: 10px; border-radius: 5px;">
                    <span class="fw-bold text-dark">FarmAdmin</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link px-3 custom-nav-link text-uppercase fw-bold" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 custom-nav-link text-uppercase fw-bold" asp-controller="Field" asp-action="Index">
                                <i class="bi bi-map me-1"></i> Fields
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 custom-nav-link text-uppercase fw-bold" asp-controller="Crop" asp-action="Index">
                                <i class="bi bi-flower1 me-1"></i> Crops
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 custom-nav-link text-uppercase fw-bold" asp-controller="Resource" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i> Inventory
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 custom-nav-link text-uppercase fw-bold" asp-controller="ResourceUsage" asp-action="Index">
                                <i class="bi bi-journal-text me-1"></i> Logs
                            </a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-success rounded-pill shadow-sm px-4 fw-bold text-white" asp-controller="PlantSchedule" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i> Planting Calendar
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container d-flex justify-content-between align-items-center py-3">
            <span>&copy; 2026 - FarmAdmin - Farm Management & Crop Monitoring</span>
            <ul class="nav">
                <li class="nav-item">
                    <a class="nav-link custom-nav-link text-uppercase fw-bold p-0" asp-controller="Home" asp-action="Privacy">
                        <i class="bi bi-shield-lock me-1"></i> Privacy
                    </a>
                </li>
            </ul>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>