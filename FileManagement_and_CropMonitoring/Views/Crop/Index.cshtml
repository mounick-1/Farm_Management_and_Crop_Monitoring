@model IEnumerable<FarmManagement_and_CropMonitoring.Models.Crop>

@{
    ViewData["Title"] = "Crops List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Manage Crops</h1>
        <a asp-action="Create" class="btn btn-success">Add New Crop</a>
    </div>

    <table class="table table-hover border">
        <thead class="table-light">
            <tr>
                <th>Crop Name</th>
                <th>Type</th>
                <th>Season</th>
                <th>Field Assigned</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CropName</td>
                        <td>@item.CropType</td>
                        <td>@item.Season</td>
                        <td>@(item.Field?.FieldName ?? "No Field Assigned")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No crops found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>